# 1. Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 2. Your Groq API key — free tier, no credit card needed → https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# 3. Your Telegram numeric user ID — send /start to @userinfobot to get it
ALLOWED_USER_ID=your_telegram_numeric_user_id

# 4. Window title or process name to target for injection
#    Try: cmd | Command Prompt | Administrator: Command Prompt | wt | Windows PowerShell
TARGET_WINDOW=cmd

# 5. Process names for window switching (no .exe suffix)
#    Find them: Get-Process | Where-Object { $_.MainWindowHandle -ne 0 } | Select-Object Name, MainWindowTitle
CLAUDE_PROCESS=cmd
OBSIDIAN_PROCESS=Obsidian
FIREFOX_PROCESS=firefox
